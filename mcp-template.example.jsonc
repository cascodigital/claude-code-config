// MCP Template — generated by setup.sh
// Placeholders: {{HOME}}, {{VENV_BIN}} (Scripts vs bin), {{EXE}} (.exe vs empty)
// DO NOT use this file directly. Run setup.sh to generate ~/.claude.json
//
// Add your MCP servers here with placeholders for paths and secrets.
// Secrets go in .mcp-secrets (gitignored) and are referenced as {{SECRET_NAME}}.
{
  "mcpServers": {

    // --- Node.js MCPs ---
    // These use npm packages. setup.sh runs `npm install` if node_modules is missing.

    "memory": {
      "type": "stdio",
      "command": "node",
      "args": ["{{HOME}}/.claude/mcp-servers/memory/node_modules/@modelcontextprotocol/server-memory/dist/index.js"],
      "env": {}
    },
    "sequential-thinking": {
      "type": "stdio",
      "command": "node",
      "args": ["{{HOME}}/.claude/mcp-servers/sequential-thinking/node_modules/@modelcontextprotocol/server-sequential-thinking/dist/index.js"],
      "env": {}
    },

    // --- Python MCPs ---
    // These use venvs. setup.sh creates venv + pip install if missing.
    // {{VENV_BIN}} = "bin" (Linux/Mac) or "Scripts" (Windows)
    // {{EXE}} = "" (Linux/Mac) or ".exe" (Windows)

    "my-python-mcp": {
      "type": "stdio",
      "command": "{{HOME}}/.claude/mcp-servers/my-python-mcp/venv/{{VENV_BIN}}/python{{EXE}}",
      "args": ["{{HOME}}/.claude/mcp-servers/my-python-mcp/server.py"],
      "env": {
        "API_URL": "http://your-server:8080/api/v1",
        "API_KEY": "{{MY_API_KEY}}"
      }
    },

    // --- Remote/SSE MCPs ---
    // These connect to a running service. No local install needed.

    "remote-service": {
      "type": "sse",
      "url": "http://your-server:18082/sse"
    }
  },

  // --- Project-scoped MCPs ---
  // These are only loaded when Claude Code is opened in a specific directory.

  "projects": {
    "{{HOME_NATIVE}}": {
      "mcpServers": {
        "project-specific-mcp": {
          "type": "stdio",
          "command": "node",
          "args": ["{{HOME}}/.claude/mcp-servers/project-mcp/node_modules/project-mcp/dist/index.js"],
          "env": {
            "PROJECT_API_KEY": "{{PROJECT_API_KEY}}"
          }
        }
      }
    }
  }
}
